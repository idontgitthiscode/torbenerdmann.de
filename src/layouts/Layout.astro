---
/* src/layouts/Layout.astro */
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <div id="boot-loader" class="boot-loader-container">
      <div class="loader-content">
        <span class="loader-butterfly">🦋</span>
        <div class="loader-bar-container">
          <div class="loader-bar-fill"></div>
        </div>
        <p class="loader-text green-text">System booting...</p>
      </div>
    </div>

    <nav class="desktop-top-bar" id="os-top-bar" style="opacity: 0;">
      <div class="bar-left">
        <span class="os-logo">🦋</span>
        <span class="menu-item bold">Torben OS</span>
        <span class="menu-item">File</span>
        <span class="menu-item">Edit</span>
        <span class="menu-item">Terminal</span>
      </div>
      
      <div class="bar-right">
        <div class="system-status">
          <span class="status-icon" title="Verbunden">📶</span>
          <span class="status-icon" title="100% geladen">🔋</span>
        </div>
        <div id="system-time">00:00</div>
      </div>
    </nav>

    <div class="desktop-icons" id="os-icons" style="opacity: 0;">
      <a href="https://github.com/idontgitthiscode/torbenerdmann.de" target="_blank" class="icon-link">
        <div class="icon">
          <span class="icon-img">🐙</span> 
          <span class="icon-label">GitHub</span>
        </div>
      </a>


      <a href="https://www.linkedin.com/in/torben-fabian-erdmann/" target="_blank" class="icon-link">
        <div class="icon">
          <span class="icon-img">🔗</span> 
          <span class="icon-label">LinkedIn</span>
        </div>
      </a>
    </div>

    <div class="desktop-wallpaper"></div>

    <main id="os-main" style="opacity: 0;">
      <slot />
    </main>

    <script>
      // 1. Script für Uhrzeit & Datum
      function updateTime() {
        const now = new Date();
        const options: Intl.DateTimeFormatOptions = { 
          weekday: 'short', 
          day: 'numeric', 
          month: 'long',
          hour: '2-digit', 
          minute: '2-digit' 
        };
        const timeStr = now.toLocaleString('de-DE', options);
        const el = document.getElementById('system-time');
        if (el) el.textContent = timeStr;
      }
      setInterval(updateTime, 1000);
      updateTime();

      // 2. Script für den Boot-Loader & Einblenden
      window.addEventListener('load', () => {
        const loader = document.getElementById('boot-loader');
        const elementsToFade = ['os-top-bar', 'os-icons', 'os-main'];

        setTimeout(() => {
          if (loader) {
            loader.style.opacity = '0';
            loader.style.pointerEvents = 'none';
          }

          elementsToFade.forEach(id => {
            const el = document.getElementById(id);
            if (el) {
              el.style.transition = 'opacity 1s ease-in';
              el.style.opacity = '1';
            }
          });

          setTimeout(() => {
            if (loader) loader.style.display = 'none';
          }, 1000);
        }, 3000);
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --accent-green: #2ea043;
  }

  body {
    margin: 0;
    padding: 0;
    height: 100vh;
    width: 100vw;
    overflow: hidden;
    background-color: #000;
    font-family: 'JetBrains Mono', monospace;
  }

  /* LOADER STYLES */
  .boot-loader-container {
    position: fixed;
    inset: 0;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    transition: opacity 0.8s ease;
  }

  .loader-content { display: flex; flex-direction: column; align-items: center; }
  .loader-butterfly { font-size: 5rem; margin-bottom: 20px; animation: pulse 2s infinite ease-in-out; }
  .loader-bar-container { width: 200px; height: 4px; background: #333; border-radius: 2px; overflow: hidden; }
  .loader-bar-fill { width: 0%; height: 100%; background: var(--accent-green); animation: loading 3s forwards ease-in-out; }
  .loader-text { margin-top: 15px; font-size: 0.8rem; }
  .green-text { color: var(--accent-green); }

  @keyframes loading { to { width: 100%; } }
  @keyframes pulse { 0%, 100% { transform: scale(1); opacity: 0.8; } 50% { transform: scale(1.1); opacity: 1; } }

  /* UI STYLES */
  .desktop-wallpaper {
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    background-image: url('/images/torben_os_wallpaper.png'); 
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    z-index: -1;
    filter: brightness(0.6);
  }

  .desktop-top-bar {
    position: fixed;
    top: 0; left: 0; width: 100%; height: 32px;
    background: rgba(13, 17, 23, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(48, 54, 61, 0.5);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 15px; font-size: 0.8rem; z-index: 1000; color: #fff;
    box-sizing: border-box;
  }

  .desktop-icons {
    position: absolute; 
    top: 60px; 
    left: 25px;
    display: flex; 
    flex-direction: column; 
    gap: 30px; 
    z-index: 20!important; /* Liegt ÜBER dem main-layer */
  }
  
  .icon-link {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }
  
  .icon { 
    display: flex; 
    flex-direction: column; 
    align-items: center; 
    width: 75px; 
    opacity: 0.9; 
    transition: 0.2s;
  }
  
  .icon:hover { opacity: 1; transform: scale(1.05); }
  .icon-img { font-size: 2.2rem; filter: drop-shadow(0 4px 8px rgba(0,0,0,0.8)); }
  .icon-label { 
    font-size: 0.65rem; color: #fff; margin-top: 5px;
    background: rgba(0,0,0,0.5); padding: 2px 8px; border-radius: 4px;
    text-shadow: 0 1px 2px #000; text-align: center; min-width: 60px;
  }

  /* MAIN & TERMINAL INTERACTION FIX */
  main {
    display: flex; 
    align-items: center; 
    justify-content: center;
    height: 100vh; 
    width: 100vw; 
    position: relative; 
    z-index: 10;
    pointer-events: none; /* Lässt Klicks auf Icons durch */
  }

  /* Terminal muss Klicks wieder annehmen */
  main > * {
    pointer-events: auto;
  }

  .bar-left { display: flex; gap: 15px; align-items: center; }
  .bar-right { display: flex; align-items: center; gap: 15px; font-weight: 500; white-space: nowrap; }
  .system-status { display: flex; gap: 8px; font-size: 1rem; opacity: 0.9; }
  .menu-item { color: #8b949e; cursor: default; }
  .bold { color: #fff; font-weight: bold; }
  .os-logo { font-size: 1.1rem; color: #fff; }

  

@media (max-width: 1124px) {
  .desktop-icons { 
    display: none !important;
  }
  @media (max-width: 1124px) {
  

  /* 2. Die Icons in eine horizontale Glas-Bar verwandeln */
  .desktop-icons {
    display: flex !important;
    flex-direction: row !important; /* Horizontal nebeneinander */
    justify-content: center;
    gap: 40px;
    
    /* Positionierung am unteren Rand */
    position: fixed !important;
    bottom: 30px;
    left: 50% !important;
    transform: translateX(-50%);
    top: auto !important; /* Überschreibt das 'top: 60px' vom Desktop */
    
    /* Glassmorphism Design */
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 15px 30px;
    border-radius: 24px;
    width: fit-content;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }

  /* Icon-Größe für Mobile leicht anpassen */
  .icon-img {
    font-size: 1.8rem;
  }
  
  .icon-label {
    background: transparent; /* Text-Hintergrund weg für cleaner Look im Dock */
    font-size: 0.6rem;
  }

  /* 3. Topbar aufräumen */
  .menu-item:not(.bold), .bar-right {
    display: none !important;
  }
  .desktop-top-bar {
    justify-content: center;
  }
}
}
</style>