---
/* Terminal.astro - Draggable Terminal mit sauberem Design */
---

<section class="terminal-container">
  <div class="terminal-window reveal active" id="terminal-window">
    <div class="terminal-header">
      <div class="terminal-controls">
        <span class="control close"></span>
        <span class="control minimize"></span>
        <span class="control maximize"></span>
      </div>
      <div class="terminal-title">qash — guest@torbenerdmann.de</div>
    </div>
    
    <div class="terminal-body" id="terminal-body">
      <div id="terminal-history">
        <div class="line">
          <span class="prompt">guest@portfolio:~$</span>
          <span class="command">system --init</span>
        </div>
        <div class="terminal-output-line">
          <h1 class="name-display">
            <span class="white">Torben</span> 
            <span class="green-box">Erdmann</span>
          </h1>
          <p class="role-title">Technical Project Manager</p>
          <p class="hint">Tippe <span class="highlight">help</span> um alle Befehle zu sehen.</p>
        </div>
      </div>

      <div class="command-line">
        <span class="prompt">guest@portfolio:~$</span>
        <div class="input-wrapper">
          <input type="text" id="terminal-input" autofocus autocomplete="off" spellcheck="false" />
          <span id="terminal-typer"></span>
          <span class="block-cursor"></span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // --- 1. TERMINAL LOGIK (Commands & Input) ---
  const input = document.getElementById('terminal-input') as HTMLInputElement;
  const typer = document.getElementById('terminal-typer');
  const history = document.getElementById('terminal-history');
  const body = document.getElementById('terminal-body');

  const COMMANDS = {
    help: "Befehle: <span class='blue'>story</span>, <span class='blue'>skills</span>, <span class='blue'>contact</span>, <span class='blue'>clear</span>",
    skills: "• AWS Lightsail, Hetzner, Plesk, Docker<br/>• Astro, HTML/CSS, WordPress<br/>• Jira, Confluence, Github",
    story: "Vom Techniker zum Projektleiter. Ich sorge dafür, dass Dev-Teams und Business-Ziele die gleiche Sprache sprechen.",
    contact: "E-Mail: <a href='mailto:torben.erdmann@gmail.com' class='blue'>torben.erdmann@gmail.com</a><br/>GitHub: <a href='https://github.com/TorbenErdmann' target='_blank' class='blue'>/TorbenErdmann</a>",
  };

  input?.addEventListener('input', (e) => {
    if (typer) typer.textContent = (e.target as HTMLInputElement).value;
  });

  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const fullCmd = (e.target as HTMLInputElement).value.trim().toLowerCase();
      if (fullCmd === 'clear') {
        if (history) history.innerHTML = '';
      } else {
        const line = document.createElement('div');
        line.className = 'line';
        line.innerHTML = `<span class="prompt">guest@portfolio:~$</span> <span class="command">${fullCmd}</span>`;
        history?.appendChild(line);

        const response = document.createElement('div');
        response.className = 'terminal-output-line';
        response.innerHTML = COMMANDS[fullCmd] || `<span class="red">Fehler: Befehl '${fullCmd}' unbekannt.</span>`;
        history?.appendChild(response);
      }
      input.value = '';
      if (typer) typer.textContent = '';
      if (body) body.scrollTop = body.scrollHeight;
    }
  });

  // Klick ins Fenster fokussiert den Input
  document.addEventListener('click', () => input?.focus());

  // --- 2. DRAG & DROP LOGIK ---
  const terminal = document.getElementById('terminal-window');
  const header = terminal?.querySelector('.terminal-header') as HTMLElement;

  let isDragging = false;
  let offsetX = 0;
  let offsetY = 0;

  header?.addEventListener('mousedown', (e) => {
    isDragging = true;
    offsetX = e.clientX - terminal!.getBoundingClientRect().left;
    offsetY = e.clientY - terminal!.getBoundingClientRect().top;
    header.style.cursor = 'grabbing';
  });

  document.addEventListener('mousemove', (e) => {
    if (!isDragging) return;

    const x = e.clientX - offsetX;
    const y = e.clientY - offsetY;

    terminal!.style.position = 'fixed';
    terminal!.style.left = `${x}px`;
    terminal!.style.top = `${y}px`;
    terminal!.style.margin = '0'; 
    terminal!.style.transform = 'none'; 
  });

  document.addEventListener('mouseup', () => {
    isDragging = false;
    if (header) header.style.cursor = 'grab';
  });
</script>

<style>
  .terminal-container {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
  }

  .terminal-window {
    width: 100%;
    max-width: 900px;
    background: #0d1117;
    border: 1px solid #30363d;
    border-radius: 12px;
    height: 600px;
    display: flex;
    flex-direction: column;
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.7);
    position: relative; 
    z-index: 999;
    overflow: hidden; /* FIX: Ecken sauber abschneiden */
    user-select: none; /* Verhindert Textmarkierung beim Dragging */
    opacity: 0;
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .terminal-header {
    background: #161b22;
    padding: 12px 16px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid #30363d;
    flex-shrink: 0;
    cursor: grab; 
    border-top-left-radius: 11px;
    border-top-right-radius: 11px;
  }

  .terminal-header:active { cursor: grabbing; }

  .terminal-controls { display: flex; gap: 8px; position: absolute; }
  .control { width: 12px; height: 12px; border-radius: 50%; }
  .close { background: #ff5f56; }
  .minimize { background: #ffbd2e; }
  .maximize { background: #27c93f; }

  .terminal-title { width: 100%; text-align: center; color: #8b949e; font-size: 0.8rem; font-family: monospace; }

  .terminal-body {
    padding: 1rem 1.5rem;
    overflow-y: auto;
    flex-grow: 1;
    font-family: 'JetBrains Mono', monospace;
    text-align: left;
    scrollbar-width: thin;
    scrollbar-color: #30363d transparent;
    color: #e6edf3 !important;
    user-select: text; /* Text im Terminal wieder markierbar machen */
  }

  /* Kommandozeile */
  .line { display: flex; gap: 10px; margin-bottom: 6px; justify-content: flex-start; }
  .command-line { display: flex; align-items: center; gap: 10px; justify-content: flex-start; margin-top: 5px; }
  .input-wrapper { display: flex; align-items: center; position: relative; }

  #terminal-input { position: absolute; width: 100%; opacity: 0; border: none; outline: none; cursor: text; }
  #terminal-typer { color: #fff; white-space: pre; }

  .block-cursor {
    width: 10px;
    height: 1.2rem;
    background-color: #fff;
    animation: blink 1s step-end infinite;
    margin-left: 2px;
  }

  @keyframes blink { 50% { opacity: 0; } }

  .prompt { color: #2ea043; font-weight: bold; white-space: nowrap; }
  .command { color: #fff; }
  
  .name-display { font-size: clamp(1.8rem, 6vw, 3.2rem); margin: 0.5rem 0 1rem 0; font-weight: 800; display: flex; gap: 15px; }
  .green-box { background: #2ea043; color: #0d1117; padding: 0 10px; display: inline-block; }
  .white { color: #fff; }
  .role-title { color: #8b949e; font-size: 1.3rem; margin-bottom: 1rem; }

  .terminal-output-line { margin-bottom: 1.2rem; line-height: 1.5; color: #e6edf3; }
  .highlight { color: #2ea043; text-decoration: underline; }
  .blue { color: #58a6ff; text-decoration: none; }
  .blue:hover { text-decoration: underline; }
  .red { color: #f85149; }

  /* Animation */
  .reveal.active { opacity: 1; transform: translateY(0); }

  @media (max-width: 600px) {
    .terminal-window { height: 75vh; position: relative !important; left: auto !important; top: auto !important; }
    .name-display { font-size: 1.8rem; gap: 8px; }
  }
</style>