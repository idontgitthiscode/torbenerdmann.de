---
/* Terminal.astro - Draggable Terminal mit minimalistischem Blue-Control-Design */
---

<section class="terminal-container">
  <div class="terminal-window reveal active" id="terminal-window">
    <div class="terminal-header">
      <div class="terminal-controls">
        <span class="control close"></span>
        <span class="control minimize"></span>
        <span class="control maximize"></span>
      </div>
      <div class="terminal-title">qash — guest@torbenerdmann.de</div>
    </div>
    
    <div class="terminal-body" id="terminal-body">
      <div id="terminal-history">
        <div class="line">
          <span class="prompt">guest@portfolio:~$</span>
          <span class="command">system --init</span>
        </div>
        <div class="terminal-output-line">
          <h1 class="name-display">
            <span class="white">Torben</span> 
            <span class="green-box">Erdmann</span>
          </h1>
          <p class="role-title">Technical Project Manager</p>
          <p class="hint">Type <span class="highlight">help</span> to see all commands.</p>
        </div>
      </div>

      <div class="command-line">
        <span class="prompt">guest@portfolio:~$</span>
        <div class="input-wrapper">
          <input type="text" id="terminal-input" autofocus autocomplete="off" spellcheck="false" />
          <span id="terminal-typer"></span>
          <span class="block-cursor"></span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // --- 1. TERMINAL LOGIK ---
  const input = document.getElementById('terminal-input') as HTMLInputElement;
  const typer = document.getElementById('terminal-typer');
  const history = document.getElementById('terminal-history');
  const body = document.getElementById('terminal-body');
  const terminal = document.getElementById('terminal-window');

  const COMMANDS = {
    help: "Commands: <span class='blue'>story</span>, <span class='blue'>skills</span>, <span class='blue'>contact</span>, <span class='blue'>clear</span>",
    skills: "• AWS Lightsail, Hetzner, Plesk, Docker<br/>• Astro, HTML/CSS, WordPress<br/>• Jira, Confluence, Github",
    story: "I started in customer support and sales, learning firsthand what users actually need. I taught myself the technical side—from hosting to web development. I’ve been working as a Technical Project Manager for the last years, bridging the gap between customer needs and technical execution.",
    hobbies: "In my free time, I enjoy playing guitar, reading, family time, and gaming.",  
    contact: "LinkedIn: <a href='https://www.linkedin.com/in/torben-fabian-erdmann/' target='_blank' class='blue'>/torben-fabian-erdmann</a><br/>GitHub: <a href='https://github.com/idontgitthiscode' target='_blank' class='blue'>/idontgitthiscode</a>",
  };

  input?.addEventListener('input', (e) => {
    if (typer) typer.textContent = (e.target as HTMLInputElement).value;
  });

  input?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const fullCmd = (e.target as HTMLInputElement).value.trim().toLowerCase();
      if (fullCmd === 'clear') {
        if (history) history.innerHTML = '';
      } else {
        const line = document.createElement('div');
        line.className = 'line';
        line.innerHTML = `<span class="prompt">guest@portfolio:~$</span> <span class="command">${fullCmd}</span>`;
        history?.appendChild(line);

        const response = document.createElement('div');
        response.className = 'terminal-output-line';
        response.innerHTML = COMMANDS[fullCmd] || `<span class="red">Fehler: Befehl '${fullCmd}' unbekannt.</span>`;
        history?.appendChild(response);
      }
      input.value = '';
      if (typer) typer.textContent = '';
      if (body) body.scrollTop = body.scrollHeight;
    }
  });

  // Schließen-Logik für den blauen Punkt
  const closeBtn = document.querySelector('.control.close');
  closeBtn?.addEventListener('click', () => {
    if (terminal) terminal.style.display = 'none';
  });

  document.addEventListener('click', () => input?.focus());

  // --- 2. DRAG & DROP LOGIK ---
  const header = terminal?.querySelector('.terminal-header') as HTMLElement;
  let isDragging = false;
  let offsetX = 0;
  let offsetY = 0;

  header?.addEventListener('mousedown', (e) => {
    isDragging = true;
    offsetX = e.clientX - terminal!.getBoundingClientRect().left;
    offsetY = e.clientY - terminal!.getBoundingClientRect().top;
    header.style.cursor = 'grabbing';
  });

  document.addEventListener('mousemove', (e) => {
    if (!isDragging) return;
    terminal!.style.position = 'fixed';
    terminal!.style.left = `${e.clientX - offsetX}px`;
    terminal!.style.top = `${e.clientY - offsetY}px`;
    terminal!.style.margin = '0'; 
    terminal!.style.transform = 'none'; 
  });

  document.addEventListener('mouseup', () => {
    isDragging = false;
    if (header) header.style.cursor = 'grab';
  });
</script>

<style>
  .terminal-container {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
  }

  .terminal-window {
    width: 100%;
    max-width: 900px;
    background: #0d1117;
    border: 1px solid #30363d;
    border-radius: 12px;
    height: 600px;
    display: flex;
    flex-direction: column;
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.7);
    position: relative; 
    z-index: 999;
    overflow: hidden;
    user-select: none;
    opacity: 0;
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .terminal-header {
    background: #161b22;
    padding: 12px 16px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid #30363d;
    flex-shrink: 0;
    cursor: grab;
  }

  /* NEUE CONTROLS: Hellblauer Punkt */
  .terminal-controls { 
    display: flex; 
    gap: 8px; 
    position: absolute; 
    left: 16px;
  }

  .control { 
    width: 12px; 
    height: 12px; 
    border-radius: 50%; 
    background: #58a6ff; 
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  .control:hover { opacity: 1; cursor: pointer; }

  .minimize, .maximize { display: none; } /* Nur der Close-Button bleibt */

  .terminal-title { width: 100%; text-align: center; color: #8b949e; font-size: 0.8rem; font-family: monospace; }

  .terminal-body {
    padding: 1rem 1.5rem;
    overflow-y: auto;
    flex-grow: 1;
    font-family: 'JetBrains Mono', monospace;
    text-align: left;
    color: #e6edf3 !important;
    user-select: text;
  }

  .line { display: flex; gap: 10px; margin-bottom: 6px; }
  .command-line { display: flex; align-items: center; gap: 10px; margin-top: 5px; }
  .input-wrapper { display: flex; align-items: center; position: relative; }
  #terminal-input { position: absolute; width: 100%; opacity: 0; border: none; outline: none; }
  #terminal-typer { color: #fff; white-space: pre; }

  .block-cursor {
    width: 10px;
    height: 1.2rem;
    background-color: #fff;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink { 50% { opacity: 0; } }

  .prompt { color: #2ea043; font-weight: bold; }
  .name-display { font-size: clamp(1.8rem, 6vw, 3.2rem); margin: 0.5rem 0 1rem 0; font-weight: 800; display: flex; gap: 15px; }
  .green-box { background: #2ea043; color: #0d1117; padding: 0 10px; }
  .white { color: #fff; }
  .role-title { color: #8b949e; font-size: 1.3rem; margin-bottom: 1rem; }
  .terminal-output-line { margin-bottom: 1.2rem; line-height: 1.5; }
  .highlight { color: #2ea043; text-decoration: underline; }
  .blue { color: #58a6ff; text-decoration: none; }
  .red { color: #f85149; }

  .reveal.active { opacity: 1; transform: translateY(0); }

  /* MOBILE POSITIONING */
  @media (max-width: 1124px) {
    .terminal-container {
      align-items: flex-start;
      padding-top: 150px;
    }
    .terminal-window {
      height: 60vh;
      max-height: 450px;
      position: relative !important;
      left: auto !important;
      top: auto !important;
      margin: 0 auto;
    }
  }
</style>